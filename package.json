{
  "name": "learnboard",
  "private": true,
  "workspaces": ["client", "server", "shared"],
  "scripts": {
    "dev": "npm run dev --workspace=client & npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=client",
    "build:client": "npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "start": "npm run start --workspace=server",
    "deploy:client": "npm run deploy --workspace=client",
    "lint": "npm run lint --workspace=client"
  },
  "dependencies": {
    "zustand": "^5.0.14"
  }
}
